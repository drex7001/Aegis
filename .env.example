# --- Semantic pass (LangChain init_chat_model, provider-agnostic) ---
# Format: "provider:model". Install the matching langchain-<provider> package.
#   anthropic:claude-sonnet-5   (needs ANTHROPIC_API_KEY + langchain-anthropic)
#   openai:gpt-5                (needs OPENAI_API_KEY   + langchain-openai)
#   ollama:llama3               (local, no key          + langchain-ollama)
EXTRACTION_MODEL=google_genai:gemini-2.5-flash-lite
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Ingestion (docs/INGESTION.md) ---
# Speech-to-text model for legacy/pipeline/transcribe.py (any HF Whisper checkpoint works)
# SINHALA_ASR_MODEL=Lingalingeswaran/whisper-small-sinhala

# --- Neo4j (only needed for --push; .cypher file export works without) ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Aegis Phase 1 infra (speckit T1; `make up` works without a .env — these
# --- are the compose defaults, listed for overriding) ---
# Always 127.0.0.1, never localhost: on Windows `localhost` tries IPv6 ::1
# first and the compose ports are IPv4-only, so every connection eats a ~2s
# stall before falling back (see aegis/config.py).
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis-dev
POSTGRES_DB=aegis
AEGIS_DATABASE_URL=postgresql+psycopg://aegis:aegis-dev@127.0.0.1:5433/aegis
MINIO_ROOT_USER=aegis
MINIO_ROOT_PASSWORD=aegis-minio-dev
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_EVIDENCE_BUCKET=evidence
MINIO_SECURE=false
# Set to filesystem for an offline/dev fallback; content lands under AEGIS_VAULT_PATH.
AEGIS_VAULT_BACKEND=minio
AEGIS_VAULT_PATH=.aegis/vault
# Keycloak stays on localhost: this is the OIDC *issuer* identity and must
# match the `iss` claim Keycloak mints, or every token 401s (aegis/config.py).
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=aegis
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
FGA_API_URL=http://127.0.0.1:8082
# FGA_STORE_ID / FGA_MODEL_ID are written by `make bootstrap` to infra/.runtime.env
# In-process ADR-014 outbox dispatcher; successful inline revocations are immediate.
AEGIS_AUTHZ_OUTBOX_INTERVAL_SECONDS=5
AEGIS_AUTHZ_OUTBOX_BATCH_SIZE=100

# --- Temporary legacy /api/* containment (T16a; routes are deleted at P2 T22) ---
AEGIS_LEGACY_API_MAX_RESPONSE_BYTES=5242880
AEGIS_LEGACY_API_RATE_LIMIT_PER_MINUTE=60

# --- Tests ---
# The disposable database the integration/system suites run against. Same
# 127.0.0.1 rule as above — this one is connection-heavy, so `localhost` here
# costs hours, not seconds.
AEGIS_TEST_DATABASE_URL=postgresql+psycopg://aegis:aegis-dev@127.0.0.1:5433/aegis
